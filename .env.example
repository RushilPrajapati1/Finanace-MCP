# Copy to .env and adjust. All variables are prefixed with FINLEDGER_.

# SQLAlchemy async connection string (asyncpg driver).
FINLEDGER_DATABASE_URL=postgresql+asyncpg://finledger:finledger@localhost:5432/finledger

# Free-form environment label surfaced on the health endpoint.
FINLEDGER_ENVIRONMENT=development

# Connection pool tuning.
FINLEDGER_DB_POOL_SIZE=10
FINLEDGER_DB_MAX_OVERFLOW=20

# Set to true ONLY when running behind a trusted reverse proxy (Render, nginx).
# Controls whether X-Forwarded-For is believed for the audit-trail source IP.
FINLEDGER_TRUST_PROXY_HEADERS=false
